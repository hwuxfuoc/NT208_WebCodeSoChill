{
  "problem_number": 10,
  "title": "Regular Expression Matching",
  "function": "isMatch",
  "params": [
    {
      "name": "s",
      "type": "string"
    },
    {
      "name": "p",
      "type": "string"
    }
  ],
  "return": {
    "type": "boolean"
  },
  "testcases": [
    {
      "s": "aa",
      "p": "a",
      "expected": "false"
    },
    {
      "s": "aa",
      "p": "a*",
