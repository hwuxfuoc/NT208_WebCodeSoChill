{
  "problem_number": 199,
  "title": "Binary Tree Right Side View",
  "function": "rightSideView",
  "params": [
    {
      "name": "root",
      "type": "TreeNode"
    }
  ],
  "return": {
    "type": "list<integer>",
    "dealloc": true
  },
  "testcases": [
    {
      "root": "[1,2,3,null,5,null,4]",
      "expected": [
        1,
        3,
        4
      ]
    },
    {
      "root": "[1,2,3,4,null,null,null,5]",
      "expected": [
        1,
        3,
        4,
        5
      ]
    },
    {
      "root": "[1,null,3]",
      "expected": [
        1,
        3
      ]
    },
    {
      "root": [],
      "expected": []
    }
  ]
}