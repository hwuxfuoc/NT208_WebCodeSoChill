{
  "problem_number": 100,
  "title": "Same Tree",
  "function": "isSameTree",
  "params": [
    {
      "name": "p",
      "type": "TreeNode"
    },
    {
      "name": "q",
      "type": "TreeNode"
    }
  ],
  "return": {
    "type": "boolean"
  },
  "testcases": [
    {
      "p": [
        1,
        2,
        3
      ],
      "q": [
        1,
        2,
        3
      ],
      "expected": "true"
    },
    {
      "p": [
        1,
        2
      ],
      "q": "[1,null,2]",
      "expected": "false"
    },
    {
      "p": [
        1,
        2,
        1
      ],
      "q": [
        1,
        1,
        2
      ],
      "expected": "false"
    }
  ]
}